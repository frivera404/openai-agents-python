import pytest
pytest.skip("Removed passed voice test", allow_module_level=True)

from __future__ import annotations

try:
    from .fake_models import FakeWorkflow
except ImportError:
    pass


def test_workflow_run() -> None:
    wf = FakeWorkflow([["a"]])
    out = wf.run_sync("in")
    assert out == [["a"]]
